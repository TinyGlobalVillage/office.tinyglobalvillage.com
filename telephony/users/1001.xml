    <variables>
      <variable name="toll_allow" value="domestic,international,local"/>
      <variable name="accountcode" value="1001"/>
      <variable name="user_context" value="office.tinyglobalvillage.com"/>
      <variable name="effective_caller_id_name" value="TGV Front Desk"/>
      <variable name="effective_caller_id_number" value="18772469848"/>
