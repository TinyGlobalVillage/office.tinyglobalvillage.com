<!--
  Event Socket Library: binds localhost:8021 for outbound command sockets from
  the Node service, and listens on 8040 for the inbound ESL socket() handoffs
  (via the frontdesk dialplan).
-->
<configuration name="event_socket.conf" description="Socket Client">
  <settings>
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="127.0.0.1"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="${FRONTDESK_ESL_PASSWORD}"/>
    <param name="apply-inbound-acl" value="localhost"/>
  </settings>
</configuration>
