<include>
  <!-- TGV Office front-desk context. Installed as dialplan/office.tinyglobalvillage.com.xml
       by /srv/refusion-core/telephony/scripts/render-config.sh. -->
  <context name="office.tinyglobalvillage.com">

    <!-- Inbound: every Front Desk DID (8772469848 toll-free + 7077508469
         Telnyx) lands here via public-dispatcher transfer.

         Flat flow (no execute_extension recursion) — REVISED 2026-07-02:
         the press-1 consent IVR is RETIRED. Inbound calls are NOT recorded
         at answer; recording starts only when the agent hits the REC toggle
         (uuid_record via /api/frontdesk/calls/record), which broadcasts
         "This call is now being recorded" into the call. Flow:
           1. Answer + welcome prompt ("Welcome to Tiny Global Village, your
              call is being forwarded to one of our agents"), ringback set so
              the caller hears US ring tone during the bridge attempt.
           2. Voicemail-mode check via mod_db `office/voicemail_mode`:
                "always"   — skip bridge entirely (timeout=1).
                "fallback" — try bridging to user/1001 for 25s. (default)
           3. After bridge ends (success → hangup_after_bridge; failure →
              continue_on_fail), play the voicemail greeting (custom if
              recorded, else default), beep, record caller message, encrypt
              on hangup. -->
    <extension name="frontdesk-inbound">
      <condition field="destination_number" expression="^(8772469848|7077508469)$">
        <action application="answer"/>
        <action application="sleep" data="300"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="continue_on_fail=true"/>
        <!-- US-style ring tone played to caller during the bridge attempt. -->
        <action application="set" data="ringback=%(2000,4000,440,480)"/>
        <action application="set" data="transfer_ringback=%(2000,4000,440,480)"/>
        <action application="set" data="instant_ringback=true"/>

        <!-- Welcome greeting (Piper TTS — telephony/scripts/generate-prompts.sh). -->
        <action application="playback" data="${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/prompts/welcome-forwarding.wav"/>

        <!-- Voicemail-mode toggle: shrinks the call_timeout to 1s when set
             to "always", so the bridge fails fast and we fall through to
             the voicemail flow. Default is "fallback" → 25s ring. -->
        <action application="set" data="vm_mode=${db(select/office/voicemail_mode)}"/>
        <action application="set" data="call_timeout=${cond(${vm_mode} == always ? 1 : 25)}"/>
        <action application="bridge" data="user/1001@office.tinyglobalvillage.com"/>

        <!-- Voicemail flow (only reached on bridge fail / no-answer):
             greeting (custom if recorded, else default) → vm-record IVR
             below (instructions → tone → record; '#' opens the options
             menu: listen / re-record / send). Prompts are Piper cori-high
             (British female) — telephony/scripts/generate-prompts.sh. -->
        <action application="set" data="vm_greeting=${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/voicemails/greeting.wav"/>
        <action application="set" data="vm_default_greeting=${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/prompts/voicemail-default.wav"/>
        <action application="set" data="vm_message_file=${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/voicemails/${strftime(%Y-%m-%d-%H-%M-%S)}_${uuid}.wav"/>
        <action application="set" data="vm_prompts=${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/prompts"/>
        <!-- Pick custom greeting if it exists; else default. file_exists()
             returns "true" or "false" as a string. -->
        <action application="set" data="vm_play=${cond(${file_exists(${vm_greeting})} == true ? ${vm_greeting} : ${vm_default_greeting})}"/>
        <action application="playback" data="${vm_play}"/>
        <action application="transfer" data="vm-record XML office.tinyglobalvillage.com"/>
      </condition>
    </extension>

    <!-- Voicemail record + options IVR (2026-07-03). The caller records
         after the tone; '#' (or 3s silence / 120s cap) ends the take and
         opens the options menu: 1 = listen back, 2 = re-record (overwrites
         the same take), 3 / timeout / hangup = send. Hanging up at ANY
         point keeps the last take — api_hangup_hook encrypts it. -->
    <extension name="vm-record">
      <condition field="destination_number" expression="^vm-record$">
        <action application="playback" data="${vm_prompts}/vm-instructions.wav"/>
        <action application="set" data="RECORD_APPEND=false"/>
        <action application="set" data="playback_terminators=#"/>
        <action application="set" data="api_hangup_hook=system /srv/refusion-core/telephony/scripts/encrypt-recording.sh ${vm_message_file}"/>
        <action application="playback" data="tone_stream://%(500,0,800)"/>
        <action application="record" data="${vm_message_file} 120 200 3"/>
        <action application="transfer" data="vm-menu XML office.tinyglobalvillage.com"/>
      </condition>
    </extension>

    <extension name="vm-menu">
      <condition field="destination_number" expression="^vm-menu$">
        <action application="set" data="vm_digit="/>
        <action application="play_and_get_digits" data="0 1 3 6000 # ${vm_prompts}/vm-options.wav silence_stream://250 vm_digit [123]"/>
        <action application="transfer" data="vm-menu-${vm_digit} XML office.tinyglobalvillage.com"/>
      </condition>
    </extension>

    <extension name="vm-menu-1">
      <condition field="destination_number" expression="^vm-menu-1$">
        <action application="playback" data="${vm_message_file}"/>
        <action application="transfer" data="vm-menu XML office.tinyglobalvillage.com"/>
      </condition>
    </extension>

    <extension name="vm-menu-2">
      <condition field="destination_number" expression="^vm-menu-2$">
        <action application="transfer" data="vm-record XML office.tinyglobalvillage.com"/>
      </condition>
    </extension>

    <!-- 3 = send; also the empty-digit (timeout / no input) landing. -->
    <extension name="vm-menu-send">
      <condition field="destination_number" expression="^vm-menu-(3)?$">
        <action application="playback" data="${vm_prompts}/vm-goodbye.wav"/>
        <action application="hangup" data="NORMAL_CLEARING"/>
      </condition>
    </extension>

    <!-- Conditional recording — OUTBOUND-only since 2026-07-02 (the inbound
         consent IVR is retired; inbound records exclusively via the agent's
         mid-call REC toggle). Starts record_session when the softphone sent
         X-Record: true (pre-call checkbox), and announces it to both legs
         at answer. Kept as a sub-extension so the non-recording branch
         falls through to `bridge` cleanly without an `<anti-action>` block.

         api_hangup_hook: on hangup FS runs `system <script> <wav>` which
         encrypts the recording with the TGV Recordings GPG public key and
         removes the plaintext (telephony-security Item 3, 2026-05-01). The
         /api/frontdesk/calls/recordings/[id]/audio endpoint decrypts on
         playback. Failure is logged to /var/log/freeswitch/recording-encrypt.log;
         on failure the plaintext is preserved (better than losing the
         recording entirely). -->
    <extension name="record-if-consented" continue="true">
      <condition field="${consent_acknowledged}" expression="^true$">
        <action application="record_session" data="${recording_file}"/>
        <action application="set" data="api_hangup_hook=system /srv/refusion-core/telephony/scripts/encrypt-recording.sh ${recording_file}"/>
        <!-- Announce checkbox-started recording once the call is answered. -->
        <action application="set" data="api_on_answer=uuid_broadcast ${uuid} ${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/prompts/rec-started.wav both"/>
      </condition>
    </extension>

    <!-- Internal: extension-to-extension calls within this tenant.
         Gate REVISED 2026-07-02 (was ${sip_authorized}, Item 5 2026-05-02):
         sip.js v0.21 verifiably ABANDONS challenged INVITEs (FS log uuid
         6e582edc: 407 sent → detach → "Abandoned" → WRONG_CALL_STATE), so
         per-INVITE digest can't be required. Call authorization instead =
         source must be the loopback WSS (only reachable through nginx
         /sip-ws, which REQUIRES an Office login via auth_request) + REGISTER
         is still digest-authed + UFW denies public 5060. Spoofed inbound
         trunk traffic arrives from Telnyx IPs, not 127.0.0.1, and falls
         through. -->
    <extension name="local-ext">
      <condition field="${network_addr}" expression="^127\.0\.0\.1$" break="on-false">
        <condition field="destination_number" expression="^(10[0-9][0-9])$">
          <action application="bridge" data="user/$1@office.tinyglobalvillage.com"/>
        </condition>
      </condition>
    </extension>

    <!-- Outbound: softphone placing calls via Telnyx gateway.
         Caller-ID selection: softphone sends `X-CID: +E164` to pick which DID
         shows on the callee side. Falls back to the gateway default. Any
         non-account number would be rejected by Telnyx (D51).
         Codec: Telnyx SIP trunks only accept PCMU/PCMA. Chrome's WebRTC
         INVITE offers OPUS, PCMU, PCMA — so we force PCMU on BOTH legs
         (browser supports it alongside OPUS) to eliminate transcoding and
         the codec re-negotiation that fails when the b-leg answers late on
         a WebRTC channel. The {absolute_codec_string=PCMU,PCMA} prefix on
         the bridge dial-string still scopes the b-leg explicitly; setting
         it as a channel variable locks the a-leg too, and late-negotiation
         will honor it when building the 200 OK SDP answer to the browser. -->
    <!-- Gate REVISED 2026-07-02 (was ${sip_authorized}, Item 5 2026-05-02;
         see local-ext comment for the sip.js 407 evidence): only calls
         originating from the loopback WSS may reach the outbound bridge.
         That path is unreachable without an Office login (nginx auth_request
         on /sip-ws) and the softphone's REGISTER is still digest-authed.
         Toll-fraud INVITEs from the public internet never arrive with
         network_addr 127.0.0.1 (UFW denies public 5060; 5080 is Telnyx-CIDR
         only), so even if a destination regex slips, an attacker cannot
         reach the Telnyx bridge. This remains the most important defense
         against toll fraud at the dialplan layer. -->
    <extension name="outbound-telnyx">
      <condition field="${network_addr}" expression="^127\.0\.0\.1$" break="on-false">
        <condition field="destination_number" expression="^\+?(1?\d{10,})$">
        <action application="set" data="absolute_codec_string=PCMU,PCMA"/>
        <action application="set" data="ignore_early_media=ring_ready"/>
        <action application="set" data="instant_ringback=true"/>
        <action application="set" data="effective_caller_id_number=${cond(${sip_h_X-CID} != '' ? ${sip_h_X-CID} : ${gw_tgv_office_caller_id})}"/>
        <!-- Outbound recording is OPT-IN (2026-07-02, supersedes the Item 4/B2
             opt-out): record ONLY when the softphone explicitly sent
             X-Record: true. The softphone always sends the header, so the
             no-header fallback (false) only fires for non-softphone INVITEs —
             which must never be silently recorded. Mid-call recording is
             handled separately via uuid_record (/api/frontdesk/calls/record).
             consent_acknowledged propagates to the CDR via /api/frontdesk/calls/log. -->
        <action application="set" data="consent_acknowledged=${cond(${sip_h_X-Record} == true ? true : false)}"/>
        <action application="set" data="recording_file=${base_dir}/../../clients/office.tinyglobalvillage.com/telephony/data/recordings/${strftime(%Y-%m-%d-%H-%M-%S)}_${uuid}.wav"/>
        <action application="execute_extension" data="record-if-consented XML office.tinyglobalvillage.com"/>
        <!-- rtp_secure_media=mandatory is gated on Telnyx-side TLS+SRTP
             being live. While the trunk is still on plain UDP/RTP, leave
             this commented out — flipping it on without the TLS gateway
             will fail every outbound bridge with an SDP-encryption error.
             Cutover step ships with telephony-security Item 2 (see
             telnyx-tgv-office.xml.tls.disabled cutover comment).
        <action application="set" data="rtp_secure_media=mandatory"/>
        -->
        <action application="bridge" data="{absolute_codec_string=PCMU,PCMA}sofia/gateway/telnyx-tgv-office/$1"/>
        </condition>
      </condition>
    </extension>

  </context>
</include>
