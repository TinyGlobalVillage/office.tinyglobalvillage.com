{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "preserveSymlinks": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/lib/domains/navigation/*": ["../../packages/@tgv/module-core/module-component-library/domains/navigation/*"],
      "@/lib/domains/support/*": ["../../packages/@tgv/module-connect/module-support/support/*"],
      "@/lib/domains/editor/*": ["../../packages/@tgv/module-core/module-page-editor/editor/*"],
      "@/lib/components/*": ["../../packages/@tgv/module-core/module-component-library/components/*"],
      "@tgv/module-component-library/*": ["../../packages/@tgv/module-core/module-component-library/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
