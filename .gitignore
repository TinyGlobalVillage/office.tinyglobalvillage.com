# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# Phase 4 reconciliation audit trail (runtime, per-env)
data/reconcile/

# runtime auth/user store — written live by the app (passkey public keys,
# totpEnabled, recovery-code hashes, display data). NOT source. Lives on disk +
# in the nightly Tier 1 restic backup; restore from backup on a rebuild, not git.
data/users.json

# Front Desk runtime data — live operator state; a deploy must never clobber it
data/frontdesk/*.json
