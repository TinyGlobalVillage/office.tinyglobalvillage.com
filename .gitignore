# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local

# Phase 4 reconciliation audit trail (runtime, per-env)
data/reconcile/

# runtime auth/user store — written live by the app (passkey public keys,
# totpEnabled, recovery-code hashes, display data). NOT source. Lives on disk +
# in the nightly Tier 1 restic backup; restore from backup on a rebuild, not git.
data/users.json

# Front Desk runtime data — live operator state; a deploy must never clobber it
data/frontdesk/*.json

# Chat / DM / call / notes runtime state — same class as data/users.json above, but
# these were left TRACKED, so every deploy's git sync tried to revert live messages
# to whatever was last committed (caught 2026-07-18: direct-messages.json had 8 lines
# of that day's DMs that a checkout would have thrown away). Untracked now; they live
# on disk + in the nightly restic backup, restored from backup on a rebuild, not git.
data/chat-messages.json
data/direct-messages.json
data/ring-calls.json
data/user-notes.json

# Backup bookkeeping — written by the backup/restore-test jobs on whichever box runs
# them; committing it ships one box's history over another's.
data/backups/manifest.json
data/backups/restore-test-history.json

# Hardening audit trail — runtime security events (auth enrolments, killswitch
# flips). Same class as data/users.json: written live, per-box, restored from
# backup on a rebuild. Committing it would ship one box's log over another's.
data/audit/

# Telephony runtime audio — live operator state; deploys must never clobber it
telephony/data/voicemails/
telephony/data/recordings/
*.bak
*.bak-*
*-backup.sql
